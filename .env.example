# Jira Configuration
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_USER_EMAIL=your-email@example.com
JIRA_API_TOKEN=your-jira-api-token
JIRA_PROJECT_KEY=PF

# Anthropic Claude API (used for semantic similarity computation)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Optional: similarity threshold override (default: 0.80)
SIMILARITY_THRESHOLD=0.80

# Optional: path to persist run state (default: ./.run-state.json)
RUN_STATE_PATH=./.run-state.json

# Optional: path to run log file (default: ./logs/run-log.jsonl)
RUN_LOG_PATH=./logs/run-log.jsonl

# ── Sprint 3: Won't Do Candidate Pipeline ─────────────────────────────────────

# Slack Bot Token (required for Sprint 3)
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token

# Slack channel for Won't Do approval messages (default: #shin-test-space)
SLACK_CHANNEL=#shin-test-space

# Product Ops — Slack user IDs (required for routing)
SLACK_USER_DARSHINI=U_DARSHINI_USER_ID    # Academy, Engage
SLACK_USER_BRYAN=U_BRYAN_USER_ID           # Identity & Payments
SLACK_USER_JIN_CHOY=U_JIN_CHOY_USER_ID    # AI & Innovation, Transform

# Squad Leads — Slack user IDs (required for routing)
SLACK_USER_SAMBRUCE=U_SAMBRUCE_USER_ID     # Transform
SLACK_USER_PALAK=U_PALAK_USER_ID           # Engage
SLACK_USER_NATASHA=U_NATASHA_USER_ID       # Identity & Payments
SLACK_USER_AMANDA=U_AMANDA_USER_ID         # Academy
SLACK_USER_SURESH=U_SURESH_USER_ID         # AI & Innovation

# Won't Do thresholds (optional)
WONT_DO_LOW_IMPACT_THRESHOLD=2.0     # Impact score below this triggers low-impact rule
WONT_DO_REMINDER_INTERVAL_HOURS=24  # Hours between reminders
WONT_DO_MAX_REMINDERS=3             # Max reminder attempts before giving up

# Slack interaction server port (default: 3000)
PORT=3000

# ── Sprint 4: Weekly Bug Digest ───────────────────────────────────────────────

# Custom field ID on Product Feedback tickets that stores the owning team name.
# Since tickets live in the Product Feedback project (not team projects), the
# team is derived from this custom field. (default: customfield_10060)
JIRA_FIELD_TEAM=customfield_10060

# Cron expression for the weekly bug digest (default: every Monday 8:00 AM)
WEEKLY_DIGEST_CRON=0 8 * * 1

# Timezone for the cron job (default: Asia/Kuala_Lumpur)
WEEKLY_DIGEST_TIMEZONE=Asia/Kuala_Lumpur

# Impact score fields on Parking Lot tickets (used for digest scoring)
JIRA_FIELD_CUSTOMER_SEGMENT_WEIGHT=customfield_10050
JIRA_FIELD_AI_SEVERITY=customfield_10051

# Team project keys for delivery project linking (comma-separated "TeamName:KEY" pairs)
JIRA_TEAM_PROJECT_KEYS=Engage:ENG,Transform:TRF,AI & Innovation:AIINN,Academy:ACA,Identity & Payments:IAP

# ── Sprint 5: Monthly Feature Digest ─────────────────────────────────────────

# Confluence integration (required for Confluence page writes; digest still runs if absent)
CONFLUENCE_BASE_URL=https://your-org.atlassian.net/wiki
CONFLUENCE_USER_EMAIL=your-email@example.com
CONFLUENCE_API_TOKEN=your-atlassian-api-token
CONFLUENCE_SPACE_KEY=PM

# Cron expression for the monthly feature digest (default: first Monday of each month 8:00 AM)
# Standard cron: "0 8 1-7 * 1" = Mondays that fall on day 1-7 of the month = first Monday
MONTHLY_DIGEST_CRON=0 8 1-7 * 1

# Path to the Won't Do resurfacing state file (default: ./state/resurfacing-state.json)
RESURFACING_STATE_PATH=./state/resurfacing-state.json

# ── Sprint 6: Adoption Tracker & Scheduling Hardening ────────────────────────

# Cron expression for the quarterly adoption check (default: first Monday of Jan, Apr, Jul, Oct at 8:00 AM)
# "0 8 1-7 1,4,7,10 1" = Mondays that fall on day 1-7 of months 1, 4, 7, 10 = first Monday of each quarter
QUARTERLY_ADOPTION_CRON=0 8 1-7 1,4,7,10 1
